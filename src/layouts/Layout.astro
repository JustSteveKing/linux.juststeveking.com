---
import '@fontsource-variable/inter';
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import CommandPalette from '../components/CommandPalette.svelte';
import { getCollection } from 'astro:content';
import SEO from '../components/ui/SEO.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title,
  description,
  image,
} = Astro.props;

const currentPath = Astro.url.pathname;
const distrosRaw = await getCollection('distros');
const distros = distrosRaw.map(d => ({
  id: d.id,
  name: d.data.name,
  tagline: d.data.tagline,
  icon_slug: d.data.icon_slug,
  color: d.data.color || '#00ff66',
  slug: d.id,
  based_on: d.data.based_on,
  release_model: d.data.release_model,
  use_cases: d.data.use_cases,
  desktop_environments: d.data.desktop_environments,
  searchContent: `${d.data.name} ${d.data.tagline}`.toLowerCase(),
  iconPath: '',
}));
---

<!doctype html>
<html lang="en">
  <head>
    <SEO {title} {description} {image} />
    <ViewTransitions />
  </head>
  <body class="antialiased selection:bg-[var(--accent)] selection:text-black">
    <div class="fixed inset-0 pointer-events-none -z-10 bg-[url('/noise.png')] opacity-20 mix-blend-overlay"></div>

    <header class="fixed top-0 inset-x-0 z-50 glass-panel border-b-0 border-b-[var(--border)] border-b">
      <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 text-white no-underline group">
          <div class="w-8 h-8 rounded-lg bg-black border border-[#333] flex items-center justify-center group-hover:border-[var(--accent)] transition-colors">
            <span class="font-mono text-[var(--accent)] text-sm font-bold">~</span>
          </div>
          <span class="font-bold tracking-tight text-lg">DistroFind</span>
        </a>

        <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
          <a href="/distros" class:list={["transition-colors hover:text-white", currentPath.includes('/distros') ? "text-white" : "text-[var(--text-muted)]"]}>Catalog</a>
          <a href="/compare" class:list={["transition-colors hover:text-white", currentPath.includes('/compare') ? "text-white" : "text-[var(--text-muted)]"]}>Compare</a>
          <a href="/finder" class:list={["transition-colors hover:text-white", currentPath.includes('/finder') ? "text-white" : "text-[var(--text-muted)]"]}>Finder</a>
        </nav>

        <div class="flex items-center gap-3">
          <button id="search-trigger" class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#111] border border-[#222] text-[#888] text-xs font-mono hover:border-[var(--accent)] hover:text-[var(--accent)] transition-all">
            <span>Search</span>
            <span class="px-1.5 py-0.5 rounded bg-black border border-[#333]">⌘K</span>
          </button>
        </div>
      </div>
    </header>

    <main class="min-h-screen pt-24 pb-20">
      <div class="max-w-7xl mx-auto px-6">
        <slot />
      </div>
    </main>

    <footer class="border-t border-[var(--border)] bg-[#050505]">
      <div class="max-w-7xl mx-auto px-6 py-12 flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="flex items-center gap-2">
          <span class="font-mono text-[var(--text-muted)]">root@distrofind:~#</span>
          <span class="w-2 h-4 bg-[var(--accent)] animate-pulse"></span>
        </div>
        <p class="text-sm text-[var(--text-muted)]">
          Built for the Linux community. Open source forever.
        </p>
      </div>
    </footer>

    <CommandPalette client:load distros={distros} />

    <script>
      const searchTrigger = document.getElementById('search-trigger');
      searchTrigger?.addEventListener('click', () => {
        window.dispatchEvent(new KeyboardEvent('keydown', { key: 'k', metaKey: true, bubbles: true }));
      });
    </script>
  </body>
</html>
