---
import '@fontsource-variable/inter';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import CommandPalette from '../components/CommandPalette.svelte';
import { getCollection } from 'astro:content';
import SEO from '../components/ui/SEO.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title,
  description,
  image,
} = Astro.props;

const currentPath = Astro.url.pathname;
const distrosRaw = await getCollection('distros');
const distros = distrosRaw.map(d => ({
  id: d.id,
  name: d.data.name,
  tagline: d.data.tagline,
  icon_slug: d.data.icon_slug,
  color: d.data.color || '#00ff66',
  slug: d.id,
  based_on: d.data.based_on,
  release_model: d.data.release_model,
  use_cases: d.data.use_cases,
  desktop_environments: d.data.desktop_environments,
  searchContent: `${d.data.name} ${d.data.tagline}`.toLowerCase(),
  iconPath: '',
}));
---

<!doctype html>
<html lang="en">
  <head>
    <SEO {title} {description} {image} />
    <ClientRouter />
  </head>
  <body class="antialiased selection:bg-(--accent) selection:text-black">
    <div class="fixed inset-0 pointer-events-none -z-10 opacity-[0.03] mix-blend-overlay" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>

    <header class="fixed top-0 inset-x-0 z-50 glass-panel border-b-0 border-b-(--border)">
      <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 text-white no-underline group">
          <div class="w-8 h-8 rounded-lg bg-black border border-[#333] flex items-center justify-center group-hover:border-(--accent) transition-colors">
            <span class="font-mono text-(--accent) text-sm font-bold">~</span>
          </div>
          <span class="font-bold tracking-tight text-lg">DistroFind</span>
        </a>

        <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
          <a href="/distros" class:list={["transition-colors hover:text-white", currentPath.includes('/distros') ? "text-white" : "text-(--text-muted)"]}>Catalog</a>
          <a href="/compare" class:list={["transition-colors hover:text-white", currentPath.includes('/compare') ? "text-white" : "text-(--text-muted)"]}>Compare</a>
          <a href="/finder" class:list={["transition-colors hover:text-white", currentPath.includes('/finder') ? "text-white" : "text-(--text-muted)"]}>Finder</a>
        </nav>

        <div class="flex items-center gap-3">
          <button id="search-trigger" class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#111] border border-[#222] text-[#888] text-xs font-mono hover:border-(--accent) hover:text-(--accent) transition-all">
            <span>Search</span>
            <span class="px-1.5 py-0.5 rounded bg-black border border-[#333]">⌘K</span>
          </button>
          <button id="mobile-menu-trigger" class="md:hidden w-8 h-8 flex flex-col items-center justify-center gap-1.5 text-white cursor-pointer" aria-label="Toggle Menu">
            <span class="w-5 h-0.5 bg-current transition-all duration-300 origin-center" id="m-t-1"></span>
            <span class="w-5 h-0.5 bg-current transition-all duration-300 origin-center" id="m-t-2"></span>
          </button>
        </div>
      </div>
    </header>

    <!-- Mobile Menu Drawer -->
    <div id="mobile-menu" class="fixed inset-0 top-16 bg-[#050505] z-60 translate-x-full transition-transform duration-500 md:hidden flex flex-col p-8 gap-10 overflow-y-auto invisible">
      <div class="flex flex-col gap-2">
        <span class="text-[0.6rem] font-mono text-[#444] uppercase tracking-widest font-bold">Navigation_Routes</span>
        <a href="/distros" class="text-3xl font-black text-white hover:text-(--accent) transition-colors py-4 border-b border-[#111]">Catalog</a>
        <a href="/compare" class="text-3xl font-black text-white hover:text-(--accent) transition-colors py-4 border-b border-[#111]">Compare</a>
        <a href="/finder" class="text-3xl font-black text-white hover:text-(--accent) transition-colors py-4 border-b border-[#111]">Finder</a>
      </div>
      
      <div class="mt-auto pt-8 border-t border-[#111]">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-10 h-10 rounded-xl bg-[#0a0a0a] border border-[#222] flex items-center justify-center text-(--accent)">
            <span class="font-mono font-bold">~</span>
          </div>
          <span class="font-black text-white uppercase tracking-widest text-xs">DistroFind Engine</span>
        </div>
        <p class="text-xs text-[#555] font-medium leading-relaxed">Algorithmic discovery for the Linux community. Open source forever.</p>
      </div>
    </div>

    <main class="min-h-screen pt-24 pb-20">
      <div class="max-w-7xl mx-auto px-6">
        <slot />
      </div>
    </main>

    <footer class="border-t border-(--border) bg-[#050505]">
      <div class="max-w-7xl mx-auto px-6 py-12 flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="flex items-center gap-2">
          <span class="font-mono text-(--text-muted)">root@distrofind:~#</span>
          <span class="w-2 h-4 bg-(--accent) animate-pulse"></span>
        </div>
        <p class="text-sm text-(--text-muted)">
          Built for the Linux community. Open source forever.
        </p>
      </div>
    </footer>

    <CommandPalette client:load distros={distros} />

    <script>
      function initLayout() {
        const searchTrigger = document.getElementById('search-trigger');
        searchTrigger?.addEventListener('click', () => {
          window.dispatchEvent(new KeyboardEvent('keydown', { key: 'k', metaKey: true, bubbles: true }));
        });

        // Mobile Menu Logic
        const menuTrigger = document.getElementById('mobile-menu-trigger');
        const menu = document.getElementById('mobile-menu');
        const t1 = document.getElementById('m-t-1');
        const t2 = document.getElementById('m-t-2');
        let isMenuOpen = false;

        function toggleMenu() {
          isMenuOpen = !isMenuOpen;
          if (menu) {
            menu.classList.toggle('translate-x-full', !isMenuOpen);
            // Ensure visibility when opening
            menu.style.visibility = isMenuOpen ? 'visible' : 'hidden';
          }
          document.body.style.overflow = isMenuOpen ? 'hidden' : '';
          
          // Transform hamburger to X
          if (t1 && t2) {
            t1.style.transform = isMenuOpen ? 'rotate(45deg) translateY(4px)' : '';
            t2.style.transform = isMenuOpen ? 'rotate(-45deg) translateY(-4px)' : '';
          }
        }

        // Remove existing listener if any (to prevent multiple)
        menuTrigger?.removeEventListener('click', toggleMenu);
        menuTrigger?.addEventListener('click', toggleMenu);

        // Close menu on link click
        const menuLinks = menu?.querySelectorAll('a');
        menuLinks?.forEach(link => {
          link.addEventListener('click', () => {
            if (isMenuOpen) toggleMenu();
          });
        });
      }

      // Initialize on load and after ogni swap
      initLayout();
      document.addEventListener('astro:page-load', initLayout);
    </script>
  </body>
</html>
