---
interface Props {
  class?: string;
  size?: 'sm' | 'md' | 'lg' | 'xl' | 'full';
}

const { class: className, size = 'lg' } = Astro.props;

const sizes = {
  sm: 'max-w-3xl',
  md: 'max-w-5xl',
  lg: 'max-w-7xl',
  xl: 'max-w-screen-2xl',
  full: 'max-w-none'
};

const classes = [
  'mx-auto px-6 w-full',
  sizes[size],
  className
].filter(Boolean).join(' ');
---

<div class={classes}>
  <slot />
</div>
