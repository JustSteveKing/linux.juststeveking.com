---
interface Props {
  class?: string;
  padding?: 'none' | 'sm' | 'md' | 'lg' | 'xl';
  variant?: 'surface' | 'elevated' | 'glass';
  hover?: boolean;
  [key: string]: any;
}

const { 
  class: className, 
  padding = 'md', 
  variant = 'surface',
  hover = false,
  ...rest 
} = Astro.props;

const baseStyles = "relative border border-brand-border rounded-brand-lg overflow-hidden transition-all duration-300";

const variants = {
  surface: "bg-brand-surface",
  elevated: "bg-brand-elevated",
  glass: "glass shadow-xl shadow-black/20"
};

const paddings = {
  none: "",
  sm: "p-4",
  md: "p-6",
  lg: "p-8",
  xl: "p-12"
};

const hoverStyles = hover ? "hover:border-primary/50 hover:shadow-lg hover:shadow-primary/5 hover:-translate-y-1" : "";

const classes = [
  baseStyles,
  variants[variant],
  paddings[padding],
  hoverStyles,
  className
].filter(Boolean).join(' ');
---

<div class={classes} {...rest}>
  <slot />
</div>
