---
import { getDistroIcon } from '../utils/icons';
import Tag from './ui/Tag.astro';

interface Props {
  id: string;
  name: string;
  tagline: string;
  based_on?: string | null;
  release_model: 'rolling' | 'fixed' | 'lts';
  color?: string;
  icon_slug?: string;
  use_cases: string[];
  attributes: {
    beginner_friendly: number;
    hardware_requirements: number;
    out_of_box: number;
    gaming: number;
    development: number;
  };
  index?: number;
}

const { id, name, tagline, release_model, color = '#ffffff', icon_slug, use_cases, attributes, index = 0 } = Astro.props;
const icon = getDistroIcon(icon_slug);

const releaseLabel = { rolling: 'Rolling', fixed: 'Fixed', lts: 'LTS' }[release_model];
const delay = `${index * 50}ms`;
---

<a 
  href={`/distros/${id}`}
  class="group relative block bento-card-hover p-8 md:p-10 overflow-hidden h-full flex-col gap-8 opacity-0 animate-fade-up shadow-2xl shadow-black/40"
  style={`--distro-color: ${color}; animation-delay: ${delay};`}
>
  <div class="absolute -top-12 -right-12 w-48 h-48 bg-(--distro-color) opacity-[0.03] blur-[60px] rounded-full group-hover:opacity-[0.08] transition-opacity duration-700"></div>
  
  <header class="flex items-start justify-between gap-6 relative z-10">
    <div class="flex items-center gap-5">
      <div class="w-14 h-14 rounded-xl bg-black border border-[#222] flex items-center justify-center group-hover:border-(--distro-color) group-hover:scale-105 transition-all duration-500 shadow-xl">
        {icon ? (
          <svg viewBox="0 0 24 24" class="w-7 h-7 fill-white group-hover:fill-(--distro-color)sition-colors duration-500">
            <path d={icon.path} />
          </svg>
        ) : (
          <span class="text-2xl font-black text-white group-hover:text-(--distro-color) transition-colors duration-500">{name[0]}</span>
        )}
      </div>
      <div>
        <h3 class="text-xl font-black tracking-tight text-white group-hover:text-(--distro-color) transition-colors duration-500">{name}</h3>
        <p class="text-[0.65rem] font-mono text-[#666] uppercase tracking-[0.2em] mt-1">{releaseLabel} Build</p>
      </div>
    </div>
  </header>

  <p class="text-[0.95rem] text-[#999] leading-relaxed line-clamp-2 relative z-10 flex-1 group-hover:text-white transition-colors duration-500">
    {tagline}
  </p>

  <div class="space-y-5 relative z-10">
    <div class="flex flex-col gap-2">
      <div class="flex justify-between items-center text-[0.65rem] font-mono text-[#555] uppercase tracking-widest">
        <span>User Friendly</span>
        <span class="text-[#888]">{attributes.beginner_friendly}/5</span>
      </div>
      <div class="flex gap-1.5 h-1">
        {Array.from({ length: 5 }, (_, i) => (
          <div class:list={["flex-1 rounded-full transition-all duration-700", i < attributes.beginner_friendly ? "bg-white group-hover:bg-(--distro-color) shadow-[0_0_10px_var(--distro-color)]" : "bg-[#111]"]}></div>
        ))}
      </div>
    </div>
    <div class="flex flex-col gap-2">
      <div class="flex justify-between items-center text-[0.65rem] font-mono text-[#555] uppercase tracking-widest">
        <span>Development</span>
        <span class="text-[#888]">{attributes.development}/5</span>
      </div>
      <div class="flex gap-1.5 h-1">
        {Array.from({ length: 5 }, (_, i) => (
          <div class:list={["flex-1 rounded-full transition-all duration-700", i < attributes.development ? "bg-white group-hover:bg-(--distro-color) shadow-[0_0_10px_var(--distro-color)]" : "bg-[#111]"]}></div>
        ))}
      </div>
    </div>
  </div>

  <div class="flex flex-wrap gap-2.5 mt-2 relative z-10">
    {use_cases.slice(0, 3).map(uc => (
      <Tag variant="default" class="text-[0.6rem] py-1.5 px-3">{uc}</Tag>
    ))}
  </div>
</a>
