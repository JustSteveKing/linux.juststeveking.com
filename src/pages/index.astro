---
import Layout from '../layouts/Layout.astro';
import DistroCard from '../components/DistroCard.astro';
import { getCollection } from 'astro:content';

const allDistros = await getCollection('distros');
const featured = allDistros.slice(0, 3);
---

<Layout>
  <!-- ── Hero ── -->
  <section class="hero dot-grid">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-eyebrow">
        <span class="eyebrow-dot"></span>
        <span>{allDistros.length} distributions catalogued</span>
      </div>
      <h1 class="hero-title">
        Find your perfect<br />
        <span class="gradient-text">Linux distribution</span>
      </h1>
      <p class="hero-body">
        Not sure where to start with Linux? Answer a handful of questions about
        your experience, goals, and hardware — and we'll rank every distro in
        our collection by how well it matches you.
      </p>
      <div class="hero-actions">
        <a href="/finder" class="btn btn-primary">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          Find my distro
        </a>
        <a href="/distros" class="btn btn-outline">Browse all distros</a>
      </div>
    </div>
    <div class="hero-fade" aria-hidden="true"></div>
  </section>

  <!-- ── Features ── -->
  <section class="features">
    <div class="container">
      <ul class="feature-list">
        <li class="feature-item">
          <div class="feature-icon-wrap">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <div>
            <h3>Weighted scoring</h3>
            <p>Your answers drive a scoring algorithm that weights attributes differently based on what matters most to you.</p>
          </div>
        </li>
        <li class="feature-item">
          <div class="feature-icon-wrap">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <div>
            <h3>Fully private</h3>
            <p>Everything runs in your browser. Your preferences are never sent anywhere — no tracking, no accounts.</p>
          </div>
        </li>
        <li class="feature-item">
          <div class="feature-icon-wrap">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <div>
            <h3>Rich distro profiles</h3>
            <p>Each distribution is profiled across gaming, development, stability, privacy, hardware requirements, and more.</p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- ── Featured distros ── -->
  <section class="featured-section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>Popular distributions</h2>
          <p class="section-sub">A cross-section of the collection</p>
        </div>
        <a href="/distros" class="btn btn-outline btn-sm">View all →</a>
      </div>
      <div class="distro-grid">
        {featured.map(d => (
          <DistroCard
            id={d.id}
            name={d.data.name}
            tagline={d.data.tagline}
            based_on={d.data.based_on}
            release_model={d.data.release_model}
            color={d.data.color}
            icon_slug={d.data.icon_slug}
            use_cases={d.data.use_cases}
            attributes={d.data.attributes}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-card">
        <div class="cta-glow" aria-hidden="true"></div>
        <div class="cta-content">
          <h2>Not sure which to pick?</h2>
          <p>Take the two-minute quiz and get a personalised list ranked by how closely each distribution matches your needs.</p>
          <a href="/finder" class="btn btn-primary">Start the finder →</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    padding: 6rem 0 5rem;
    overflow: hidden;
    border-bottom: 1px solid var(--border-subtle);
  }

  .hero-glow {
    position: absolute;
    top: -20%;
    left: -5%;
    width: 55%;
    height: 90%;
    background: radial-gradient(ellipse, rgba(124, 108, 245, 0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 5rem;
    background: linear-gradient(to bottom, transparent, var(--bg));
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
    max-width: 700px;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.75rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.01em;
  }

  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-green);
    box-shadow: 0 0 6px var(--accent-green);
    flex-shrink: 0;
  }

  .hero-title {
    font-size: clamp(2.25rem, 5.5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.08;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--primary) 30%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-body {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 540px;
    line-height: 1.75;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding-top: 0.25rem;
  }

  /* ── Features ── */
  .features {
    padding: 3.5rem 0;
    border-bottom: 1px solid var(--border-subtle);
  }

  .feature-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
    gap: 1.5rem;
    list-style: none;
  }

  .feature-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .feature-icon-wrap {
    flex-shrink: 0;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius);
    background: var(--primary-dim);
    border: 1px solid color-mix(in srgb, var(--primary) 25%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
    margin-top: 0.1rem;
  }

  .feature-item h3 {
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 0.3rem;
    letter-spacing: -0.01em;
  }

  .feature-item p {
    font-size: 0.84rem;
    color: var(--text-muted);
    line-height: 1.55;
  }

  /* ── Featured section ── */
  .featured-section {
    padding: 4.5rem 0;
  }

  .section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 1.75rem;
    gap: 1rem;
  }

  .section-header h2 {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.2rem;
  }

  .section-sub {
    font-size: 0.82rem;
    color: var(--text-subtle);
  }

  .distro-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
    gap: 1rem;
  }

  /* ── CTA ── */
  .cta-section {
    padding: 0 0 5rem;
  }

  .cta-card {
    position: relative;
    padding: 3rem 2.5rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .cta-glow {
    position: absolute;
    top: -40%;
    right: -10%;
    width: 50%;
    height: 150%;
    background: radial-gradient(ellipse, rgba(124, 108, 245, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-content {
    position: relative;
    z-index: 1;
    max-width: 520px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .cta-content h2 {
    font-size: 1.6rem;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .cta-content p {
    color: var(--text-muted);
    line-height: 1.65;
    font-size: 0.95rem;
  }
</style>
