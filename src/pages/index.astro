---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import Box from '../components/ui/Box.astro';
import Action from '../components/ui/Action.astro';

const distros = await getCollection('distros');
const count = distros.length;
---

<Layout 
  title="Linux OS Discovery & Algorithmic Matching" 
  description="Discover your ideal Linux distribution with our technical matching engine. Analyze 100+ technical vectors across performance, stability, and developer experience."
>
  <!-- Hero Section -->
  <section class="py-24 md:py-40 flex flex-col items-center text-center opacity-0 animate-fade-up">
    <div class="inline-flex items-center gap-2.5 px-4 py-1.5 rounded-xl border border-[#222] bg-black/50 backdrop-blur-md text-[0.65rem] font-mono text-[#888] uppercase tracking-widest mb-10 shadow-xl">
      <span class="w-2 h-2 rounded-full bg-[var(--accent)] animate-pulse shadow-[0_0_8px_var(--accent)]"></span>
      System.Index: {count} distros catalogued
    </div>
    
    <h1 class="text-6xl md:text-8xl font-black tracking-tighter text-white mb-8 leading-[0.9] text-glow">
      Find Your <br class="hidden md:block" />
      <span class="text-[var(--accent)]">Ideal OS</span>
    </h1>
    
    <p class="text-xl text-[#888] max-w-2xl mx-auto mb-12 leading-relaxed font-medium">
      Our algorithmic discovery engine analyzes dozens of technical vectors to pair you with the perfect Linux distribution.
    </p>
    
    <div class="flex flex-col sm:flex-row gap-5">
      <Action href="/finder" variant="primary" class="h-14 px-10 text-base shadow-2xl">Initialize Finder</Action>
      <Action href="/distros" variant="secondary" class="h-14 px-10 text-base">Browse Index</Action>
    </div>
  </section>

  <!-- Bento Grid -->
  <section class="grid grid-cols-1 md:grid-cols-3 gap-6 auto-rows-[minmax(200px,auto)] pb-40">
    
    <!-- Feature 1 -->
    <Box class="md:col-span-2 flex flex-col justify-end relative overflow-hidden group opacity-0 animate-fade-up animate-delay-100 min-h-[300px]">
      <div class="absolute inset-0 bg-linear-to-tr from-black via-black/80 to-transparent z-0"></div>
      <div class="absolute top-12 right-12 z-0 opacity-[0.05] group-hover:opacity-20 transition-all duration-700 group-hover:scale-110">
        <svg width="200" height="200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
      </div>
      <div class="relative z-10">
        <h3 class="text-3xl font-black text-white mb-3">Vector-Based Matching</h3>
        <p class="text-lg text-[#888] max-w-md font-medium leading-relaxed">Our matching engine analyzes 12 technical vectors per distribution to ensure a surgical fit for your hardware.</p>
      </div>
    </Box>

    <!-- Feature 2 -->
    <Box class="flex flex-col justify-end relative overflow-hidden group opacity-0 animate-fade-up animate-delay-200">
      <div class="absolute -top-20 -right-20 w-64 h-64 bg-[var(--accent)] rounded-full blur-[100px] opacity-[0.05] group-hover:opacity-15 transition-opacity duration-700"></div>
      <div class="relative z-10">
        <h3 class="text-2xl font-black text-white mb-3">Client-Side</h3>
        <p class="text-[#888] text-sm font-medium leading-relaxed">Calculation logic runs entirely in your browser. No telemetry, no logs, zero tracking.</p>
      </div>
    </Box>

    <!-- Deep Dive -->
    <Box as="a" href="/compare" class="group flex flex-col justify-between bento-card-hover opacity-0 animate-fade-up animate-delay-300 shadow-2xl">
      <div class="w-14 h-14 rounded-xl bg-[#0a0a0a] border border-[#222] flex items-center justify-center mb-10 group-hover:border-[var(--accent)] transition-colors duration-500 shadow-xl">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white group-hover:text-[var(--accent)] transition-colors duration-500"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
      </div>
      <div>
        <h3 class="text-2xl font-black text-white mb-3 group-hover:text-[var(--accent)] transition-colors duration-500">Compare Tool</h3>
        <p class="text-[#888] text-sm font-medium leading-relaxed">Side-by-side technical breakdowns across stability, gaming, and dev tooling.</p>
      </div>
    </Box>

    <!-- Stats -->
    <Box class="md:col-span-2 grid grid-cols-2 gap-12 items-center opacity-0 animate-fade-up animate-delay-400 border-[#222] relative overflow-hidden">
      <div class="absolute inset-0 opacity-[0.03] pointer-events-none mix-blend-overlay" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>
      <div class="flex flex-col gap-2 relative z-10">
        <span class="text-5xl md:text-7xl font-black text-white text-glow">{count}</span>
        <span class="text-[0.65rem] font-mono text-[#555] uppercase tracking-[0.3em] font-bold">OS Registry</span>
      </div>
      <div class="flex flex-col gap-2 border-l border-[#222] pl-12">
        <span class="text-5xl md:text-7xl font-black text-white text-glow">100%</span>
        <span class="text-[0.65rem] font-mono text-[#555] uppercase tracking-[0.3em] font-bold">Open Access</span>
      </div>
    </Box>

  </section>
</Layout>
