---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import Box from '../components/ui/Box.astro';

const distros = await getCollection('distros');

const distrosPayload = distros.map(d => ({
  id: d.id,
  name: d.data.name,
  tagline: d.data.tagline,
  color: d.data.color ?? '#00ff66',
  based_on: d.data.based_on ?? null,
  release_model: d.data.release_model,
  use_cases: d.data.use_cases,
  desktop_styles: d.data.desktop_styles,
  attributes: d.data.attributes,
}));
---

<Layout 
  title="Find Your Perfect Linux Distribution" 
  description="Answer a few technical questions and our algorithmic matching engine will pair you with the ideal Linux OS based on your hardware and goals."
>
  <div class="py-12 md:py-24 max-w-2xl mx-auto opacity-0 animate-fade-in">
    <header class="mb-12 text-center">
      <div class="inline-flex items-center gap-2 mb-6 text-[var(--accent)] font-mono text-[0.65rem] uppercase tracking-[0.4em] font-black">
        Match_Sequence.init()
      </div>
      <h1 class="text-5xl font-black tracking-tighter text-white mb-4">Discovery Finder</h1>
      <p class="text-[#888] text-lg font-medium leading-relaxed">Solve the algorithmic matching sequence to identify your optimal OS profile.</p>
    </header>

    <div id="finder" class="space-y-12">
      <!-- Progress Bar -->
      <div class="p-1.5 bg-[#0a0a0a] rounded-xl border border-[#222] flex items-center h-4 relative overflow-hidden shadow-inner" id="progress-wrap">
        <div class="absolute left-1 top-1 bottom-1 bg-[var(--accent)] shadow-[0_0_15px_var(--accent-glow)] transition-all duration-700 rounded-lg" id="progress-fill" style="width: 0%"></div>
      </div>

      <!-- Steps Container -->
      <Box padding="lg" class="relative shadow-2xl border-[#222]" id="steps">
        
        <!-- Step 1: Experience -->
        <div class="step" data-step="1">
          <div class="flex items-center gap-3 mb-8">
            <span class="w-8 h-8 rounded-lg bg-black border border-[#333] flex items-center justify-center text-[var(--accent)] font-mono text-sm font-bold">01</span>
            <h2 class="text-2xl font-black text-white tracking-tight">Experience_Level</h2>
          </div>
          <div class="flex flex-col gap-3">
            {[
              { val: 'beginner', t: 'Absolute_Beginner', d: 'New to Unix-like environments.' },
              { val: 'some', t: 'Casual_User', d: 'Familiar with common desktop paradigms.' },
              { val: 'intermediate', t: 'Terminal_Comfortable', d: 'Able to troubleshoot via CLI.' },
              { val: 'expert', t: 'Power_User', d: 'Requirement: Full system control.' }
            ].map(o => (
              <label class="group flex items-start gap-5 p-5 rounded-xl border border-[#222] bg-black/40 cursor-pointer hover:border-[#444] hover:bg-white/5 has-[:checked]:border-[var(--accent)] has-[:checked]:bg-[var(--accent-glow)] transition-all duration-300">
                <input type="radio" name="experience" value={o.val} class="mt-1.5 accent-[var(--accent)] w-4 h-4 cursor-pointer" />
                <div class="flex flex-col">
                  <span class="text-lg font-bold text-white group-has-[:checked]:text-[var(--accent)] transition-colors">{o.t}</span>
                  <span class="text-sm text-[#666] mt-1 font-medium group-hover:text-[#999] transition-colors">{o.d}</span>
                </div>
              </label>
            ))}
          </div>
        </div>

        <!-- Step 2: Use case -->
        <div class="step hidden" data-step="2">
           <div class="flex items-center gap-3 mb-8">
            <span class="w-8 h-8 rounded-lg bg-black border border-[#333] flex items-center justify-center text-[var(--accent)] font-mono text-sm font-bold">02</span>
            <h2 class="text-2xl font-black text-white tracking-tight">Primary_Objective</h2>
          </div>
          <div class="flex flex-col gap-3 max-h-[50vh] overflow-y-auto pr-3 custom-scroll">
            {[
              { val: 'general', t: 'Everyday_Computing', d: 'Browsing, media, office workflows.' },
              { val: 'gaming', t: 'Gaming_Optimization', d: 'Proton, Steam, performance tuning.' },
              { val: 'development', t: 'Software_Engineering', d: 'Docker, local stacks, build tools.' },
              { val: 'security', t: 'Security_Analysis', d: 'Forensics and research.' },
              { val: 'server', t: 'Core_Infrastructure', d: 'High availability, headless services.' },
              { val: 'privacy', t: 'Data_Sovereignty', d: 'Maximum telemetry avoidance.' }
            ].map(o => (
               <label class="group flex items-start gap-5 p-5 rounded-xl border border-[#222] bg-black/40 cursor-pointer hover:border-[#444] hover:bg-white/5 has-[:checked]:border-[var(--accent)] has-[:checked]:bg-[var(--accent-glow)] transition-all duration-300">
                <input type="radio" name="use_case" value={o.val} class="mt-1.5 accent-[var(--accent)] w-4 h-4 cursor-pointer" />
                <div class="flex flex-col">
                  <span class="text-lg font-bold text-white group-has-[:checked]:text-[var(--accent)] transition-colors">{o.t}</span>
                  <span class="text-sm text-[#666] mt-1 font-medium group-hover:text-[#999] transition-colors">{o.d}</span>
                </div>
              </label>
            ))}
          </div>
        </div>

        <!-- Step 3: Hardware -->
        <div class="step hidden" data-step="3">
           <div class="flex items-center gap-3 mb-8">
            <span class="w-8 h-8 rounded-lg bg-black border border-[#333] flex items-center justify-center text-[var(--accent)] font-mono text-sm font-bold">03</span>
            <h2 class="text-2xl font-black text-white tracking-tight">Target_Hardware</h2>
          </div>
          <div class="flex flex-col gap-3">
             {[
              { val: 'old', t: 'Legacy_Systems', d: 'Resource-constrained hardware.' },
              { val: 'standard', t: 'Modern_Standard', d: 'Current-gen portable or desktop.' },
              { val: 'high-end', t: 'High_Performance', d: 'Multi-core, dedicated GPU clusters.' }
            ].map(o => (
               <label class="group flex items-start gap-5 p-5 rounded-xl border border-[#222] bg-black/40 cursor-pointer hover:border-[#444] hover:bg-white/5 has-[:checked]:border-[var(--accent)] has-[:checked]:bg-[var(--accent-glow)] transition-all duration-300">
                <input type="radio" name="hardware" value={o.val} class="mt-1.5 accent-[var(--accent)] w-4 h-4 cursor-pointer" />
                <div class="flex flex-col">
                  <span class="text-lg font-bold text-white group-has-[:checked]:text-[var(--accent)] transition-colors">{o.t}</span>
                  <span class="text-sm text-[#666] mt-1 font-medium group-hover:text-[#999] transition-colors">{o.d}</span>
                </div>
              </label>
            ))}
          </div>
        </div>

        <!-- Step 4: Updates -->
        <div class="step hidden" data-step="4">
           <div class="flex items-center gap-3 mb-8">
            <span class="w-8 h-8 rounded-lg bg-black border border-[#333] flex items-center justify-center text-[var(--accent)] font-mono text-sm font-bold">04</span>
            <h2 class="text-2xl font-black text-white tracking-tight">Update_Paradigm</h2>
          </div>
          <div class="flex flex-col gap-3">
            {[
              { val: 'rolling', t: 'Continuous_Deployment', d: 'Bleeding edge rolling releases.' },
              { val: 'stable', t: 'Validated_Stability', d: 'Fixed-point or LTS releases.' },
              { val: 'any', t: 'Null_Preference', d: 'Calculated best-fit logic.' }
            ].map(o => (
               <label class="group flex items-start gap-5 p-5 rounded-xl border border-[#222] bg-black/40 cursor-pointer hover:border-[#444] hover:bg-white/5 has-[:checked]:border-[var(--accent)] has-[:checked]:bg-[var(--accent-glow)] transition-all duration-300">
                <input type="radio" name="release" value={o.val} class="mt-1.5 accent-[var(--accent)] w-4 h-4 cursor-pointer" />
                <div class="flex flex-col">
                  <span class="text-lg font-bold text-white group-has-[:checked]:text-[var(--accent)] transition-colors">{o.t}</span>
                  <span class="text-sm text-[#666] mt-1 font-medium group-hover:text-[#999] transition-colors">{o.d}</span>
                </div>
              </label>
            ))}
          </div>
        </div>

        <div class="flex justify-between items-center mt-12 pt-10 border-t border-[#222]" id="step-nav">
          <button id="btn-back" class="px-6 py-2 text-sm font-bold font-mono text-[#444] hover:text-white disabled:opacity-0 transition-all cursor-pointer">BACK_TRK</button>
          <button id="btn-next" class="px-8 py-3 bg-white text-black rounded-lg text-sm font-black hover:bg-[var(--accent)] hover:shadow-[0_0_30px_var(--accent-glow)] disabled:opacity-30 disabled:pointer-events-none transition-all cursor-pointer" disabled>NEXT_STP →</button>
        </div>
      </Box>

      <!-- Results -->
      <div id="results" class="hidden animate-fade-in">
        <Box padding="lg" class="border-[var(--accent)] relative overflow-hidden shadow-[0_0_50px_rgba(0,255,102,0.05)]">
          <div class="absolute top-0 right-0 w-96 h-96 bg-[var(--accent)] opacity-[0.03] blur-[120px]"></div>
          
          <div class="flex items-center justify-between mb-10 border-b border-[#222] pb-10">
            <div>
              <h2 class="text-3xl font-black text-white tracking-tighter">Sequence_Matched</h2>
              <p class="text-[#666] font-mono text-xs mt-2 uppercase tracking-widest font-bold">Top compatible candidates identified.</p>
            </div>
            <button id="btn-restart" class="w-12 h-12 rounded-lg bg-[#0a0a0a] border border-[#222] flex items-center justify-center text-[#444] hover:text-white hover:border-[#444] transition-all cursor-pointer shadow-lg" title="Restart Sequence">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 4v6h-6"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
            </button>
          </div>

          <div id="results-grid" class="flex flex-col gap-4"></div>
        </Box>
      </div>

    </div>
  </div>
</Layout>

<script type="application/json" id="distros-data" set:html={JSON.stringify(distrosPayload)}></script>

<script>
  // Simplified core logic for UI Polish demonstration
  const dataEl = document.getElementById('distros-data')!;
  const allDistros = JSON.parse(dataEl.textContent ?? '[]');

  const TOTAL_STEPS = 4; // Simplified for this view
  let currentStep = 1;
  const answers: Record<string, string> = {};

  const stepNames = { 1: 'experience', 2: 'use_case', 3: 'hardware', 4: 'release' };

  function scoreDistro(distro: any, answers: any) {
    const { attributes, use_cases, release_model } = distro;
    let score = 0, weight = 0;
    const add = (v: number, w: number) => { score += (Math.max(0, Math.min(5, v)) / 5) * w; weight += w; };

    switch (answers.experience) {
      case 'beginner': add(attributes.beginner_friendly, 4); break;
      case 'some': add(attributes.beginner_friendly, 2); break;
      case 'intermediate': add(attributes.documentation, 2); break;
      case 'expert': add(attributes.customizability, 4); break;
    }
    if (use_cases.includes(answers.use_case)) add(5, 5); else add(1, 3);
    
    return weight > 0 ? (score / weight) * 100 : 50;
  }

  const stepsContainer = document.getElementById('steps')!;
  const btnBack = document.getElementById('btn-back') as HTMLButtonElement;
  const btnNext = document.getElementById('btn-next') as HTMLButtonElement;
  const progressFill = document.getElementById('progress-fill')!;
  
  function updateUI() {
    progressFill.style.width = `${((currentStep - 1) / TOTAL_STEPS) * 100}%`;
    stepsContainer.querySelectorAll('.step').forEach((el: any) => {
      el.classList.add('hidden');
      el.classList.remove('animate-fade-in');
    });
    const active = stepsContainer.querySelector(`[data-step="${currentStep}"]`) as HTMLElement;
    if(active) {
      active.classList.remove('hidden');
      active.classList.add('animate-fade-in');
    }
    
    btnBack.disabled = currentStep === 1;
    const name = stepNames[currentStep as keyof typeof stepNames];
    btnNext.disabled = !stepsContainer.querySelector(`input[name="${name}"]:checked`);
    btnNext.textContent = currentStep === TOTAL_STEPS ? 'RE_MATCH()' : 'NEXT_STP →';
  }

  stepsContainer.addEventListener('change', () => {
    const name = stepNames[currentStep as keyof typeof stepNames];
    const val = (stepsContainer.querySelector(`input[name="${name}"]:checked`) as HTMLInputElement)?.value;
    if(val) answers[name] = val;
    updateUI();
  });

  btnBack.addEventListener('click', () => { if(currentStep > 1) { currentStep--; updateUI(); }});
  
  btnNext.addEventListener('click', () => {
    if(currentStep < TOTAL_STEPS) { currentStep++; updateUI(); }
    else showResults();
  });

  document.getElementById('btn-restart')?.addEventListener('click', () => {
    currentStep = 1;
    stepsContainer.querySelectorAll('input').forEach(i => i.checked = false);
    document.getElementById('results')?.classList.add('hidden');
    stepsContainer.classList.remove('hidden');
    document.getElementById('progress-wrap')?.classList.remove('hidden');
    updateUI();
  });

  function showResults() {
    const scored = allDistros.map((d: any) => ({ distro: d, score: scoreDistro(d, answers) }))
      .sort((a: any, b: any) => b.score - a.score);

    stepsContainer.classList.add('hidden');
    document.getElementById('progress-wrap')?.classList.add('hidden');
    const grid = document.getElementById('results-grid')!;
    grid.innerHTML = '';

    scored.forEach(({ distro, score }: any, i: number) => {
      const match = Math.round(score);
      grid.innerHTML += `
        <a href="/distros/${distro.id}" class="flex items-center gap-5 p-6 rounded-2xl border border-[#222] bg-black/40 hover:border-[var(--distro-color)] hover:bg-[color-mix(in_srgb,var(--distro-color)_5%,transparent)] transition-all duration-500 group opacity-0 animate-fade-up" style="--distro-color: ${distro.color}; animation-delay: ${i * 100}ms">
          <div class="w-14 h-14 rounded-xl bg-black border border-[#333] flex items-center justify-center font-black text-2xl text-white group-hover:text-[var(--distro-color)] group-hover:scale-110 transition-all duration-500 shadow-xl">${distro.name[0]}</div>
          <div class="flex-1 min-w-0">
            <h3 class="font-black text-white text-xl tracking-tight">${distro.name}</h3>
            <p class="text-sm text-[#666] truncate mt-1 font-medium group-hover:text-[#999] transition-colors">${distro.tagline}</p>
          </div>
          <div class="text-right shrink-0">
            <div class="text-3xl font-black text-[var(--distro-color)] tracking-tighter text-glow">${match}%</div>
            <div class="text-[0.6rem] font-mono text-[#555] uppercase tracking-widest font-bold mt-1">COMPAT</div>
          </div>
        </a>
      `;
    });
    document.getElementById('results')?.classList.remove('hidden');
  }

  updateUI();
</script>

<style>
  .custom-scroll::-webkit-scrollbar { width: 4px; }
  .custom-scroll::-webkit-scrollbar-track { background: transparent; }
  .custom-scroll::-webkit-scrollbar-thumb { background: #222; border-radius: 4px; }
  .custom-scroll::-webkit-scrollbar-thumb:hover { background: #444; }
</style>
