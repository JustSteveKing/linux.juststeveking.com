---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getDistroIcon } from '../../utils/icons';
import Box from '../../components/ui/Box.astro';
import Tag from '../../components/ui/Tag.astro';
import Action from '../../components/ui/Action.astro';

export async function getStaticPaths() {
  const distros = await getCollection('distros');
  return distros.map(distro => ({
    params: { slug: distro.id },
    props: { distro },
  }));
}

const { distro } = Astro.props;
const { data } = distro;

const icon = getDistroIcon(data.icon_slug);
const releaseLabel = { rolling: 'Rolling', fixed: 'Fixed', lts: 'LTS' }[data.release_model];

const attributes = [
  { label: 'Beginner Friendly', value: data.attributes.beginner_friendly },
  { label: 'Hardware Specs', value: data.attributes.hardware_requirements },
  { label: 'Stability', value: data.attributes.stability },
  { label: 'Customizability', value: data.attributes.customizability },
  { label: 'Out of the Box', value: data.attributes.out_of_box },
  { label: 'Documentation', value: data.attributes.documentation },
  { label: 'Community', value: data.attributes.community },
  { label: 'Gaming', value: data.attributes.gaming },
  { label: 'Development', value: data.attributes.development },
  { label: 'Privacy', value: data.attributes.privacy },
];
---

<Layout 
  title={`${data.name} Technical Profile`} 
  description={`${data.name}: ${data.tagline}. View detailed technical vectors, package managers, and user experience scores for this Linux distribution.`}
>
  <div class="py-8" style={`--distro-color: ${data.color || 'var(--accent)'};`}>
    
    <a href="/distros" class="inline-flex items-center gap-2 text-sm font-mono text-[#666] hover:text-white transition-colors mb-12">
      <span>←</span> Back to Catalog
    </a>

    <!-- Header Box -->
    <Box class="mb-6 relative overflow-hidden flex flex-col md:flex-row items-start md:items-center gap-8 border-t-4" style="border-top-color: var(--distro-color);">
      <div class="absolute top-0 right-0 w-64 h-64 bg-[var(--distro-color)] opacity-[0.03] blur-[100px] pointer-events-none"></div>
      
      <div class="w-24 h-24 shrink-0 rounded-xl bg-[#0a0a0a] border border-[#222] flex items-center justify-center shadow-xl">
        {icon ? (
          <svg viewBox="0 0 24 24" class="w-12 h-12 fill-[var(--distro-color)] drop-shadow-md">
            <path d={icon.path} />
          </svg>
        ) : (
          <span class="text-4xl font-bold text-[var(--distro-color)]">{data.name[0]}</span>
        )}
      </div>

      <div class="flex-1">
        <h1 class="text-4xl md:text-5xl font-black tracking-tighter text-white mb-2">{data.name}</h1>
        <p class="text-xl text-[#888] font-medium max-w-2xl">{data.tagline}</p>
        
        <div class="flex flex-wrap gap-2 mt-4">
          <Tag variant="accent">{releaseLabel} Release</Tag>
          {data.based_on && <Tag>Based on {data.based_on}</Tag>}
        </div>
      </div>

      <Action href={data.website} target="_blank" rel="noopener noreferrer" class="shrink-0 w-full md:w-auto">
        Visit Website ↗
      </Action>
    </Box>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start">
      <!-- Main Content -->
      <div class="md:col-span-2 flex flex-col gap-6">
        <Box>
          <h2 class="text-sm font-mono uppercase tracking-widest text-[#666] mb-4">About</h2>
          <p class="text-lg text-[#ccc] leading-relaxed">
            {data.description}
          </p>
        </Box>

        <Box>
          <h2 class="text-sm font-mono uppercase tracking-widest text-[#666] mb-6">Attribute Telemetry</h2>
          <div class="flex flex-col gap-5">
            {attributes.map(attr => (
              <div class="grid grid-cols-[140px_1fr_30px] sm:grid-cols-[180px_1fr_40px] items-center gap-4">
                <span class="text-sm font-medium text-white">{attr.label}</span>
                <div class="h-1.5 bg-[#111] rounded-full overflow-hidden">
                  <div class="h-full bg-[var(--distro-color)] shadow-[0_0_10px_var(--distro-color)] rounded-full" style={`width: ${(attr.value / 5) * 100}%`}></div>
                </div>
                <span class="text-xs font-mono text-[#888] text-right">{attr.value}/5</span>
              </div>
            ))}
          </div>
        </Box>
      </div>

      <!-- Sidebar -->
      <div class="flex flex-col gap-6 md:sticky md:top-24">
        <Box padding="md">
          <h3 class="text-xs font-mono uppercase tracking-widest text-[#666] mb-3">Package Managers</h3>
          <div class="flex flex-wrap gap-2">
            {data.package_managers.map(pm => (
              <code class="px-2 py-1 rounded bg-[#111] border border-[#222] text-[#aaa] text-xs">{pm}</code>
            ))}
          </div>
        </Box>

        <Box padding="md">
          <h3 class="text-xs font-mono uppercase tracking-widest text-[#666] mb-3">Desktop Environments</h3>
          <ul class="flex flex-col gap-2">
            {data.desktop_environments.map(de => (
              <li class="text-sm text-[#ddd] flex items-center gap-2">
                <span class="w-1 h-1 bg-[var(--distro-color)] rounded-full"></span>
                {de}
              </li>
            ))}
          </ul>
        </Box>

        <Box padding="md">
          <h3 class="text-xs font-mono uppercase tracking-widest text-[#666] mb-3">Primary Use Cases</h3>
          <div class="flex flex-wrap gap-2">
            {data.use_cases.map(uc => <Tag>{uc}</Tag>)}
          </div>
        </Box>
      </div>
    </div>

  </div>
</Layout>
