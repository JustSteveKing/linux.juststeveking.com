---
import Layout from '../../layouts/Layout.astro';
import DistroCard from '../../components/DistroCard.astro';
import { getCollection } from 'astro:content';

const distros = await getCollection('distros');
const sorted = distros.sort((a, b) => a.data.name.localeCompare(b.data.name));
const allUseCases = [...new Set(distros.flatMap(d => d.data.use_cases))].sort();
---

<Layout 
  title="Explore All Linux Distributions" 
  description="Browse our comprehensive registry of Linux distributions. Filter by use-case, analyze technical vectors, and find the right OS for your workflow."
>
  <div class="py-12 md:py-20">
    <header class="mb-16 border-b border-[#222] pb-16 opacity-0 animate-fade-in">
      <div class="inline-flex items-center gap-2 mb-6 text-[var(--accent)] font-mono text-xs uppercase tracking-[0.3em] font-bold">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--accent)]"></span>
        Distro Registry
      </div>
      <h1 class="text-5xl md:text-6xl font-black tracking-tighter text-white mb-6 leading-tight">Registry <span class="text-[#444]">/</span> Catalog</h1>
      <p class="text-[#888] text-xl max-w-2xl font-medium leading-relaxed">
        Our complete laboratory index of Linux operating systems, analyzed and graded across critical technical vectors.
      </p>
    </header>

    <div class="flex flex-col gap-12">
      <div class="flex flex-wrap gap-2.5 filter-bar opacity-0 animate-fade-in animate-delay-100" role="group">
        <button class="filter-pill px-5 py-2 rounded-lg text-[0.65rem] font-mono uppercase tracking-[0.2em] font-black border border-[#222] bg-[#0a0a0a] text-white hover:border-[var(--accent)] transition-all cursor-pointer active shadow-lg" data-filter="all">All_Distros</button>
        {allUseCases.map(uc => (
          <button class="filter-pill px-5 py-2 rounded-lg text-[0.65rem] font-mono uppercase tracking-[0.2em] font-black border border-[#222] bg-transparent text-[#666] hover:text-white hover:border-[#444] transition-all cursor-pointer shadow-sm" data-filter={uc}>{uc.replace(' ', '_')}</button>
        ))}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="distro-grid">
        {sorted.map((d, i) => (
          <div class="card-wrap transition-all duration-500" data-uses={d.data.use_cases.join(',')}>
            <DistroCard
              id={d.id}
              name={d.data.name}
              tagline={d.data.tagline}
              based_on={d.data.based_on}
              release_model={d.data.release_model}
              color={d.data.color}
              icon_slug={d.data.icon_slug}
              use_cases={d.data.use_cases}
              attributes={d.data.attributes}
              index={i}
            />
          </div>
        ))}
      </div>

      <div class="hidden py-32 text-center border-2 border-dashed border-[#222] rounded-2xl opacity-0 animate-fade-in" id="empty-state">
        <div class="w-16 h-16 rounded-xl bg-[#0a0a0a] border border-[#222] flex items-center justify-center mx-auto mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#444" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </div>
        <p class="text-[#666] font-mono text-xs uppercase tracking-[0.3em] font-black">Null Reference: No distros match criteria.</p>
      </div>
    </div>
  </div>
</Layout>

<script>
  function initFilters() {
    const bar = document.querySelector('.filter-bar');
    if (!bar || bar.dataset.init === 'true') return;

    const pills = bar.querySelectorAll<HTMLButtonElement>('.filter-pill');
    const cards = document.querySelectorAll<HTMLElement>('.card-wrap');
    const empty = document.getElementById('empty-state');

    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        const filter = pill.dataset.filter!;
        
        pills.forEach(p => {
          if(p === pill) {
            p.classList.add('bg-[#0a0a0a]', 'text-white', 'border-[var(--accent)]', 'shadow-[0_0_20px_var(--accent-glow)]');
            p.classList.remove('bg-transparent', 'text-[#666]', 'border-[#222]');
          } else {
            p.classList.remove('bg-[#0a0a0a]', 'text-white', 'border-[var(--accent)]', 'shadow-[0_0_20px_var(--accent-glow)]');
            p.classList.add('bg-transparent', 'text-[#666]', 'border-[#222]');
          }
        });

        let visible = 0;
        cards.forEach(card => {
          const show = filter === 'all' || card.dataset.uses?.split(',').includes(filter);
          card.style.opacity = show ? '1' : '0';
          card.style.transform = show ? 'scale(1)' : 'scale(0.95)';
          setTimeout(() => {
            card.style.display = show ? 'block' : 'none';
          }, 300);
          if (show) visible++;
        });

        if(empty) empty.classList.toggle('hidden', visible > 0);
      });
    });
    bar.dataset.init = 'true';
  }
  initFilters();
  document.addEventListener('astro:page-load', initFilters);
</script>
